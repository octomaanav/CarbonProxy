{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run CarbonProxy Extension",
      "type": "extensionHost",
      "request": "launch",
      "args": [
        "--extensionDevelopmentPath=${workspaceFolder}/vscode-ext/carbonproxy"
      ],
      "outFiles": [
        "${workspaceFolder}/vscode-ext/carbonproxy/dist/**/*.js"
      ],
      "preLaunchTask": "carbonproxy: compile"
    }
  ]
}
